{
  "name": "paperclip-master-chat-plugin",
  "version": "0.2.0",
  "type": "module",
  "description": "Plugin-owned master chat surface for Paperclip mediated by Hermes",
  "scripts": {
    "build": "node ./esbuild.config.mjs",
    "build:rollup": "rollup -c",
    "dev": "node ./esbuild.config.mjs --watch",
    "dev:ui": "paperclip-plugin-dev-server --root . --ui-dir dist/ui --port 4177",
    "adapter:start": "node ./dist/adapter-service.js",
    "test": "vitest run --config ./vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "audit:prod": "pnpm audit --prod --audit-level moderate",
    "repo:check": "git diff --check",
    "verify": "pnpm typecheck && pnpm test && pnpm build",
    "vps:check": "node ./scripts/vps-reuse-check.mjs",
    "vps:smoke": "node ./scripts/vps-smoke.mjs",
    "remote:smoke": "node ./scripts/remote-adapter-smoke.mjs",
    "remote:smoke:local": "node ./scripts/remote-adapter-local-smoke.mjs"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "keywords": [
    "paperclip",
    "plugin",
    "chat",
    "hermes",
    "multimodal"
  ],
  "author": "turmo.dev",
  "license": "MIT",
  "homepage": "https://github.com/Ola-Turmo/paperclip-master-chat-plugin",
  "bugs": {
    "url": "https://github.com/Ola-Turmo/paperclip-master-chat-plugin/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Ola-Turmo/paperclip-master-chat-plugin.git"
  },
  "devDependencies": {
    "@paperclipai/shared": "2026.416.0",
    "@paperclipai/plugin-sdk": "2026.416.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/node": "^24.6.0",
    "@types/react": "^19.0.8",
    "esbuild": "^0.27.3",
    "rollup": "^4.38.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
